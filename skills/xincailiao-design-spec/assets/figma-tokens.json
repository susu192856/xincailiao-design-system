        "500": "#FF3D52",
        "600": "#FF112D",
        "700": "#D90E26",
        "800": "#B30C1F",
        "900": "#8C0918"
      },
      "product-blue": {
        "50": "#EDF5FF",
        "100": "#D9EBFF",
        "200": "#B8D8FF",
        "300": "#8BBEFF",
        "400": "#5A9FFF",
        "500": "#006DEA",
        "600": "#0058C2",
        "700": "#00449A",
        "800": "#00306F",
        "900": "#001D47"
      },
      "neutral": {
        "50": "#F7F8FA",
