        "success-bg": "#ECFDF5",
        "warning-text": "#F59E0B",
        "warning-bg": "#FFFBEB",
        "error-text": "#EF4444",
        "error-bg": "#FEF2F2",
        "info-text": "#006DEA",
        "info-bg": "#EFF6FF"
      },
      "data": {
        "01": "#006DEA",
        "02": "#14B8A6",
        "03": "#8B5CF6",
        "04": "#F59E0B",
        "05": "#10B981",
        "06": "#EF4444",
        "07": "#64748B",
        "08": "#0EA5E9",
        "09": "#A855F7",
        "10": "#84CC16",
        "11": "#F97316",
        "12": "#475569"
      },
      "category": {
        "teal-text": "#0F766E",
        "teal-bg": "#F0FDFA",
        "violet-text": "#6D28D9",
        "violet-bg": "#F5F3FF",
        "slate-text": "#1E40AF",
        "slate-bg": "#EFF6FF",
        "cyan-text": "#0E7490",
        "cyan-bg": "#ECFEFF"
      }
    },
    "typography": {
      "display-l": { "fontSize": "56px", "lineHeight": "64px", "fontWeight": "700" },
      "heading-h1": { "fontSize": "40px", "lineHeight": "48px", "fontWeight": "600" },
      "heading-h2": { "fontSize": "32px", "lineHeight": "40px", "fontWeight": "600" },
      "heading-h3": { "fontSize": "24px", "lineHeight": "32px", "fontWeight": "500" },
      "heading-h4": { "fontSize": "20px", "lineHeight": "28px", "fontWeight": "500" },
      "heading-h5": { "fontSize": "18px", "lineHeight": "26px", "fontWeight": "500" },
      "body-l": { "fontSize": "16px", "lineHeight": "24px", "fontWeight": "400" },
      "body-m": { "fontSize": "14px", "lineHeight": "22px", "fontWeight": "400" },
      "body-s": { "fontSize": "13px", "lineHeight": "20px", "fontWeight": "400" },
      "caption": { "fontSize": "12px", "lineHeight": "18px", "fontWeight": "400" }
    },
    "spacing": {
      "xs": "4px", "sm": "8px", "md": "16px", "lg": "24px",
      "xl": "32px", "2xl": "48px", "3xl": "64px", "4xl": "96px"
    },
    "borderRadius": {
      "none": "0px", "sm": "2px", "md": "4px", "lg": "8px",
      "xl": "12px", "2xl": "16px", "full": "9999px"
    },
    "shadow": {
      "xs": "0 1px 2px 0 rgba(0,0,0,0.05)",
      "sm": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)",
      "md": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)",
      "lg": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)",
      "xl": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)",
      "2xl": "0 25px 50px -12px rgba(0,0,0,0.25)"
    },
    "layout": {
      "website-width": "1920px",
      "website-content": "1400px",
      "website-nav-height": "64px",
      "website-hero-sm": "500px",
      "website-hero-md": "650px",
      "website-hero-lg": "800px",
      "backend-width": "1440px",
      "backend-topbar-height": "64px",
      "backend-sidebar-expanded": "240px",
      "backend-sidebar-collapsed": "56px"
    },
    "zIndex": {
      "dropdown": "100",
      "sticky": "200",
      "overlay": "300",
      "modal": "400",
      "toast": "500",
      "tooltip": "600"
    }
  }
}
