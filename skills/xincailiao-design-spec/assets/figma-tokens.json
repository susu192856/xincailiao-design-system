{
  "version": "0.1.0",
  "description": "Figma Token 同步文件 — 与 src/styles/tokens.css 保持一对一映射。修改 tokens.css 后必须同步更新此文件。",
  "syncSource": "src/styles/tokens.css",
  "figmaFileUrl": "https://www.figma.com/design/8nsNC3DOyRpk3fA7mEmBwl/2026-新材道设计规范及组件",
  "lastSync": "2026-06-22",
  "syncRules": {
    "cssVariableFormat": "--{category}-{name}",
    "figmaTokenFormat": "{category}/{name}",
    "valueTransform": {
      "color": "直接使用 hex 值",
      "spacing": "px 值保留单位",
      "borderRadius": "px 值保留单位",
      "fontSize": "px 值保留单位",
      "lineHeight": "px 值保留单位",
      "fontWeight": "数字字符串",
      "boxShadow": "完整 CSS box-shadow 字符串"
    }
  },
  "tokens": {
